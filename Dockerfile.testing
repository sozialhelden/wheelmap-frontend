# Testing image for running Deno/Playwright e2e tests against a deployed app.
#
# The image is based on Deno because Deno is more secure by default and we can sandbox it.
#
# Build:
#
#    docker build -f Dockerfile.testing -t infra:latest-testing .
#
# Run:
#
#    docker run -e CI_TEST_DEPLOYMENT_BASE_URL=http://localhost:3000 -e CI_ARTIFACTS_PATH=/artifacts -v ./artifacts:/artifacts infra:latest-testing

FROM node:20-bookworm

RUN npx -y playwright@1.58.2 install --with-deps

# Copy test files and run script
COPY e2e/ ./e2e/
COPY run_tests.sh ./

# Run as non-root user
USER pwuser

# Run e2e tests via run_tests.sh (outputs junit, coverage, etc.)
ENTRYPOINT ["/bin/sh", "run_tests.sh"]
